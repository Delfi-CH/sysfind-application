{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "steam:*"
        },
        {
          "url": "*"
        }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://fastly.mirror.pkgbuild.com" }]
    },
    "fs:default",
    "shell:default",
    "http:default"
  ]
}